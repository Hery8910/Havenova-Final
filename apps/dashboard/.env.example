# Required in production; server-only. Never expose backend credentials in this value.
BACKEND_API_URL=https://api.example.invalid

# Required in production; NEXT_PUBLIC_* values are visible to browsers.
NEXT_PUBLIC_TENANT_KEY=tnk_example_invalid
NEXT_PUBLIC_ALLOWED_HOSTS=dashboard.example.invalid

# Optional transitional fallback for tenant resolution.
NEXT_PUBLIC_TENANT_KEY_FALLBACK=

# Legacy public backend fallbacks. Leave empty when BACKEND_API_URL is configured.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_BASE_URL=
